# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/decidoctor

# Redis
REDIS_URL=redis://localhost:6379

# LLM
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# Models
JUDGE_MODEL=claude-haiku-4-5-20251001
PERSONA_MODEL=claude-sonnet-4-6
SYNTHESIZER_MODEL=claude-sonnet-4-6

# Perplexity
PERPLEXITY_MODEL=sonar
PERPLEXITY_SEARCH_CONTEXT=low
GROUNDING_TIMEOUT_SEC=6
GROUNDING_MAX_TOKENS=1000

# Session
SESSION_TTL_SEC=3600
MAX_REQUESTION_COUNT=3
CONTEXT_WINDOW_TURNS=5
